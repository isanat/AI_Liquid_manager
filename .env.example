# The Graph API keys — get free keys at https://thegraph.com/studio/apikeys/
# System tries: key1 → key2 → public gateway → CoinGecko → static
THE_GRAPH_API_KEY=your_primary_key_here
# THE_GRAPH_API_KEY2=your_backup_key_here   # optional hot standby

# Python AI engine URL (used by Next.js API proxy)
AI_ENGINE_URL=http://localhost:8000

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
