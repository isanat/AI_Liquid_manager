# ═══════════════════════════════════════════════════════════════════
#  AI Liquid Manager — Environment Variables
#  Copy to .env and fill in your values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════

# ── The Graph API keys (Uniswap V3 subgraph) ──────────────────────
# Get free keys at https://thegraph.com/studio/apikeys/
# System tries: key1 → key2 → CoinGecko → static fallback
THE_GRAPH_API_KEY=your_primary_key_here
# THE_GRAPH_API_KEY2=your_backup_key_here   # optional hot standby

# ── Python AI engine URL (used by Next.js API proxy) ──────────────
AI_ENGINE_URL=http://localhost:8000

# ── Database (SQLite for dev, PostgreSQL for prod) ────────────────
DATABASE_URL="file:./dev.db"

# ── WalletConnect (required for WalletConnect connector) ──────────
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── Smart Contract — AILiquidVault (ERC-4626 on Arbitrum) ─────────
# Set AFTER deploying with:  forge script script/Deploy.s.sol --rpc-url arbitrum_sepolia --broadcast
NEXT_PUBLIC_VAULT_ADDRESS=                # e.g. 0x1234...abcd

# ── RPC endpoints (Arbitrum — defaults to public nodes) ───────────
# Recommended: use Alchemy or Infura for better reliability
NEXT_PUBLIC_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_RPC_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
# NEXT_PUBLIC_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_BASE=https://mainnet.base.org
# NEXT_PUBLIC_RPC_OPTIMISM=https://mainnet.optimism.io

# ── Keeper Bot (Python backend — runs on Render) ──────────────────
# The keeper calls vault.rebalance() every 15 minutes automatically.
# IMPORTANT: Use a dedicated EOA wallet (NOT your main wallet).
#            This wallet needs ETH on Arbitrum for gas (~$0.10/tx).

VAULT_ADDRESS=                            # same as NEXT_PUBLIC_VAULT_ADDRESS
KEEPER_PRIVATE_KEY=0x...                  # hex private key of strategy manager EOA
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc   # or Alchemy URL for reliability
RPC_URL_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc

# Optional: override rebalance interval (default 15 minutes)
# REBALANCE_INTERVAL=15

# Optional: max % of idle USDC to deploy per cycle (default 80)
# USDC_DEPLOY_PCT=80

# ── Smart Contract Deployment (Foundry) ───────────────────────────
# Used only when running:  forge script script/Deploy.s.sol --broadcast
DEPLOYER_PRIVATE_KEY=0x...               # deployer wallet private key
STRATEGY_MANAGER=0x...                   # keeper EOA address (receives strategy manager role)
FEE_RECIPIENT=0x...                      # address that receives vault fees
ARBISCAN_API_KEY=your_arbiscan_key       # for contract verification (free at arbiscan.io)
