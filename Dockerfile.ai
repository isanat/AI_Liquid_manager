# AI Liquidity Manager - Python AI Engine for Railway
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app

# Copy requirements and install Python dependencies
COPY ai_engine/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY ai_engine/ ./ai_engine/

# Create models directory
RUN mkdir -p /app/models/saved

# Expose default port (Railway sets PORT automatically)
EXPOSE 8000

# Health check - Railway healthchecks use the PORT env var
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:${PORT:-8000}/health || exit 1

# Start the application directly with Python
# Python will read PORT from environment
CMD ["python", "-m", "ai_engine.api.main"]
